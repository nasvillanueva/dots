#theme = dark:everforest-dark-hard,light:everforest-light-hard
theme = dark:Rose Pine Moon,light:Rose Pine Dawn
font-family = "JetBrainsMono Nerd Font Mono"
font-size = 11.5

font-family = "Noto Color Emoji"

window-show-tab-bar = never
macos-titlebar-style = hidden
window-padding-x = 14
window-padding-y = 14

macos-option-as-alt = true
copy-on-select = false
confirm-close-surface = false
scrollback-limit = 10000
mouse-hide-while-typing = true
window-save-state = never
bell-features = no-system, no-audio, no-attention, no-title, no-border

shell-integration-features = ssh-terminfo
quit-after-last-window-closed = true

keybind = clear
keybind = cmd+q=close_surface
keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

# vim: ft=ini
